{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=fileanalyzer_dev.db"
  },
  "Sandbox": {
    "SandboxPath": "sandbox_dev",
    "MaxFileSizeMB": 25,
    "AnalysisTimeoutSeconds": 60,
    "AllowedFileTypes": [
      ".pdf",
      ".txt",
      ".doc",
      ".docx",
      ".xls",
      ".xlsx",
      ".jpg",
      ".png",
      ".zip",
      ".js",
      ".exe"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Debug",
      "Microsoft.EntityFrameworkCore": "Debug",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "FileAnalysis": {
    "MaxConcurrentAnalyses": 10,
    "RetentionDays": 7,
    "EnableDetailedLogging": true
  }
}