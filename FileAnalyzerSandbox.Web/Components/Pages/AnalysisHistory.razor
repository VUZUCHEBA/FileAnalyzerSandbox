@page "/history"
@using FileAnalyzerSandbox.Application.DTOs
@using FileAnalyzerSandbox.Application.Services
@inject IFileAnalysisService FileAnalysisService
@inject IJSRuntime JS

<PageTitle>Analysis History</PageTitle>

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3>История анализа файлов</h3>
            @if (analyses != null && analyses.Any())
            {
                <button class="btn btn-danger btn-sm" @onclick="DeleteAllHistory">
                    Очистить историю 🗑️
                </button>
            }
        </div>
        <div class="card-body">
            @if (analyses == null)
            {
                <div class="text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (!analyses.Any())
            {
                <div class="alert alert-info">
                    Анализов не найдено. <a href="/upload">Загрузить файл</a>, чтобы начать.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Имя файла</th>
                                <th>Статус</th>
                                <th>Уровень угрзы</th>
                                <th>Загружен</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var analysis in analyses)
                            {
                                <tr>
                                    <td>@analysis.OriginalFileName</td>
                                    <td>
                                        <span class="badge @GetStatusBadgeClass(analysis.Status)">
                                            @analysis.Status
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @GetThreatBadgeClass(analysis.ThreatLevel)">
                                            @(analysis.ThreatLevel ?? "N/A")
                                        </span>
                                    </td>
                                    <td>@analysis.UploadedAt.ToLocalTime().ToString("dd-MM-yyyy HH:mm")</td>
                                    <td>
                                        <a href="/details/@analysis.Id" class="btn btn-sm btn-info">Подробнее</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private IEnumerable<FileAnalysisDto>? analyses;

    protected override async Task OnInitializedAsync()
    {
        await LoadAnalyses();
    }

    private async Task LoadAnalyses()
    {
        try
        {
            var userId = Guid.Parse("11111111-1111-1111-1111-111111111111");
            analyses = await FileAnalysisService.GetUserAnalysesAsync(userId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading analyses: {ex.Message}");
            analyses = new List<FileAnalysisDto>();
        }
    }

    private async Task DeleteAllHistory()
    {
        // Стандартный confirm браузера
        var confirmed = await JS.InvokeAsync<bool>("confirm", "⚠️ WARNING: Вся история будет удалена!\n\nУверены?");

        if (confirmed)
        {
            try
            {
                // Вызываем метод удаления
                await FileAnalysisService.DeleteAllAnalysesAsync();

                // Перезагружаем список
                await LoadAnalyses();

                // Обновляем UI
                StateHasChanged();

                // Показываем сообщение об успехе
                await JS.InvokeVoidAsync("alert", "✅ История очищена успешно!");
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("alert", $"❌ Ошибка: {ex.Message}");
            }
        }
    }

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Completed" => "bg-success",
        "Processing" => "bg-warning",
        "Pending" => "bg-info",
        "Failed" => "bg-danger",
        _ => "bg-secondary"
    };

    private string GetThreatBadgeClass(string? threat) => threat?.ToLower() switch
    {
        "safe" => "bg-success",
        "low" => "bg-info",
        "medium" => "bg-warning",
        "high" => "bg-danger",
        "critical" => "bg-dark",
        _ => "bg-secondary"
    };
}